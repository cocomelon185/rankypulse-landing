{
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "cache-control",
          "value": "no-store"
        }
      ]
    }
  ],
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/weekly-scan",
      "schedule": "0 9 * * 1"
    }
  ]
}
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "projects-list",
  "title": "Projects List Response",
  "description": "Shape returned by GET /api/projects",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "domain", "status"],
    "properties": {
      "id": { "type": "string" },
      "domain": { "type": "string" },
      "status": {
        "type": "string",
        "enum": ["pending", "crawling", "completed", "failed"]
      },
      "page_count": { "type": ["integer", "null"], "minimum": 0 },
      "created_at": { "type": "string" },
      "updated_at": { "type": ["string", "null"] },
      "user_id": { "type": "string" }
    }
  }
}

{
  "name": "landing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NEXT_DISABLE_TURBOPACK=1 next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "test": "playwright test",
    "test:unit": "vitest run",
    "test:headed": "playwright test --headed",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seo-check": "node scripts/seo-check.mjs",
    "seo:audit-meta": "node scripts/audit-metadata.mjs",
    "seo:bulk-fix": "node scripts/bulk-meta-fix.mjs",
    "seo:bulk-fix:apply": "node scripts/bulk-meta-fix.mjs --apply",
    "db:seed": "node scripts/seed-users.mjs",
    "qa:smoke": "playwright test --config=playwright.qa.config.ts qa/playwright/smoke.spec.ts",
    "qa:auth": "playwright test --config=playwright.qa.config.ts qa/playwright/auth.spec.ts",
    "qa:full": "playwright test --config=playwright.qa.config.ts qa/playwright/",
    "qa:crawl": "tsx qa/crawler/crawl.ts",
    "qa:discover-routes": "tsx qa/crawler/route-discovery.ts",
    "qa:discover-routes:prod": "BASE_URL=https://rankypulse.com tsx qa/crawler/route-discovery.ts",
    "qa:api": "tsx qa/api/api-health.ts",
    "qa:lighthouse": "tsx qa/lighthouse/run-lighthouse.ts",
    "qa:visual:baseline": "MODE=baseline tsx qa/visual/capture.ts",
    "qa:visual:current": "MODE=current tsx qa/visual/capture.ts",
    "qa:visual:compare": "tsx qa/visual/compare.ts",
    "qa:report": "tsx qa/reporting/generate-report.ts",
    "qa:all": "npm run qa:discover-routes && npm run qa:crawl && npm run qa:api && npm run qa:report"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@react-email/components": "^1.0.8",
    "@react-email/render": "^2.0.4",
    "@supabase/supabase-js": "^2.97.0",
    "apexcharts": "^5.6.0",
    "bcryptjs": "^3.0.3",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-apexcharts": "^2.0.1",
    "react-circular-progressbar": "^2.2.0",
    "react-countup": "^6.5.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "resend": "^6.9.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "fast-xml-parser": "^5.4.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
